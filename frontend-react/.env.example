# Required when the React app is hosted separately from Zoo.Api (Infinity Free static site, GitHub Pages, etc.).
# Must point at the deployed ASP.NET Core API root (includes `/api` because routes are `api/Animals`).
# Example: VITE_ZOO_API_BASE=https://your-zoo-api.azurewebsites.net/api
#
# Local dev: leave unset — Vite proxies `/api` to http://localhost:3000 while `npm start` runs Zoo.Api.
VITE_ZOO_API_BASE=
