{
  "name": "zoo",
  "version": "1.0.0",
  "private": true,
  "description": "JL Zoo — React frontend + ASP.NET Core (EF Core) API",
  "scripts": {
    "dev": "npm --prefix frontend-react run dev",
    "build": "npm --prefix frontend-react run build",
    "build:ghpages": "cross-env GITHUB_PAGES=true npm --prefix frontend-react run build",
    "preview": "npm --prefix frontend-react run preview",
    "start": "dotnet run --project Zoo.Api --launch-profile http",
    "test": "dotnet build \"Zoo.Api/Zoo.Api.csproj\" -c Release",
    "deploy:ghpages": "npm run build:ghpages && gh-pages -d frontend-react/dist"
  },
  "author": "Jessica Lecker",
  "license": "ISC",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "gh-pages": "^6.3.0"
  }
}
